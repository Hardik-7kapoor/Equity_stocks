def fetch_historical_from_db(stock_name, token, days=5):

    # logging.info(f"Fetching DB Data: {stock_name} | Token: {token}")

    token = str(token)

    # --- DB1: Historical (name based) ---
    client1 = MongoClient("")
    db1 = client1["Historical_DB_2"]
    collection_hist = db1[stock_name]

    # --- DB2: Live (token based) ---
    client2 = MongoClient("mongodb:")
    db2 = client2["Stocks_1MIN"]
    collection_today = db2[token]

    end_date = datetime.now()
    start_date = end_date - timedelta(days=days)
    today = datetime.now().date()

    # ========== HISTORICAL ==========
    df_hist = pd.DataFrame(
        list(collection_hist.find({
            "date": {"$gte": start_date, "$lte": end_date}
        }).sort("date", 1))
    )
    df_hist = df_hist.rename(columns={
            'date':'TIME',
            "open": "OPEN",
            "high": "HIGH",
            "low": "LOW",
            "close": "CLOSE",
            "volume": "VOLUME"
        })
    
    df_hist = df_hist[["TIME","OPEN","HIGH","LOW","CLOSE","VOLUME"]]
    # ========== TODAY LIVE ==========
    df_live = pd.DataFrame(
        list(collection_today.find({
            "date": {
                "$gte": datetime(today.year, today.month, today.day, 9, 15),
                "$lte": end_date
            }
        }).sort("date", 1))
    )

    if not df_live.empty:
        df_live.drop(columns=["_id"], errors="ignore", inplace=True)
        df_live["date"] = pd.to_datetime(df_live["date"])
        if "volume" in df_live.columns:
            df_live["VOLUME"] = df_live["volume"]
        else:
            df_live["volume"] = np.nan

        # Make live data match historical format
        df_live = df_live.rename(columns={
            'date':'TIME',
            "open": "OPEN",
            "high": "HIGH",
            "low": "LOW",
            "close": "CLOSE",
            "volume": "VOLUME"
        })

        df_live = df_live[["TIME","OPEN","HIGH","LOW","CLOSE","VOLUME"]]

    # ========== MERGE ==========
    if df_hist.empty and df_live.empty:
        return pd.DataFrame()

    df_final = pd.concat([df_hist, df_live], ignore_index=True)

    df_final = df_final.dropna(subset=["TIME"])
    df_final = df_final.sort_values("TIME").reset_index(drop=True)
    df_final = df_final.drop(columns=['_id'],errors='ignore')
    df_final = df_final.drop_duplicates(subset=["TIME"], keep="last")

    return df_final

def SuperTrend(data, atrperiod, factor):
    y = data.copy(deep=True)
    y['high'] = y['HIGH']
    y['low'] = y['LOW']
    y['close'] = y['CLOSE']
    
    hl = pd.Series(y["high"] - y["low"]).abs()
    hc = pd.Series(y["high"] - y["close"].shift()).abs()
    cl = pd.Series(y["close"].shift() - y["low"]).abs()
    hcl = pd.concat([hl, hc, cl], axis=1)
    tr = hcl.max(axis=1)
    y['hl2'] = (y['high'] + y['low']) / 2
    y['atr'] = tr.ewm(alpha=1/atrperiod, min_periods=atrperiod).mean().round(7).fillna(0)
    y['UB'] = y['hl2'] + factor * y['atr']
    y['LB'] = y['hl2'] - factor * y['atr']
    y['direction'] = 0
    y['supertrend']=0.0


    np_dtype = np.dtype({'names':y.dtypes.keys(),'formats':y.dtypes.values})
    x = np.ones(len(y),dtype= np_dtype)
    for i in y.dtypes.keys():
        x[i] = y[i].to_numpy()
    prevsupertrend=x['UB'][0]
    prevlowerband=x['LB'][0]
    prevupperband=x['UB'][0]
    for i in range(1,len(x)):
        if x['LB'][i]>prevlowerband or x['close'][i-1]<prevlowerband:
            pass
        else:
            x['LB'][i]=prevlowerband
        if x['UB'][i]<prevupperband or x['close'][i-1]>prevupperband:
            pass
        else:
            x['UB'][i]=prevupperband
        if x['atr'][i-1]==0:
            x['direction'][i]=1
        elif prevsupertrend==prevupperband:
            if x['close'][i]>x['UB'][i]:
                x['direction'][i]=-1
            else:
                x['direction'][i]=1
        else:
            if x['close'][i]<x['LB'][i]:
                x['direction'][i]=1
            else:
                x['direction'][i]=-1
        if x['direction'][i]==-1:
            prevsupertrend=x['LB'][i]
        else:
            prevsupertrend=x['UB'][i]
        prevlowerband=x['LB'][i]
        prevupperband=x['UB'][i]

    return x['direction'], x["UB"], x["LB"]

def bb(df_5min, n, k):
    df_5min['Middle'] = df_5min['CLOSE'].rolling(window=n).mean().round(2)
    df_5min['StdDev'] = df_5min['CLOSE'].rolling(window=n).std(ddof=0)
    df_5min['Upper']  = (df_5min['Middle'] + k * df_5min['StdDev']).round(2)
    df_5min['Lower']  = (df_5min['Middle'] - k * df_5min['StdDev']).round(2)
    return df_5min

