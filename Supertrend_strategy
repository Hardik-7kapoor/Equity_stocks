def candle_conversion(df, timeframe):
    df_lst = []
    apply_format = {
        "OPEN": "first",
        "HIGH": "max",
        "LOW": "min",
        "CLOSE": "last",
        "VOLUME": "sum",
    }
    # Ensure TIME is datetime
    df['TIME'] = pd.to_datetime(df['TIME'])
    
    for _, smdf in df.groupby(df['TIME'].dt.date):
        smdf = smdf.resample(timeframe, on="TIME", origin='start_day', offset="9Hr15min").apply(apply_format)
        df_lst.append(smdf)
    
    if len(df_lst) == 0:
        return pd.DataFrame()
        
    return pd.concat(df_lst).reset_index()

